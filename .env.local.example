# Contact form delivery — set one of the following:

# Option A: Webhook URL (Make.com, Zapier, n8n)
# The webhook receives a JSON body with the full consent record.
# Log it to Google Sheets or trigger an email notification from there.
CONTACT_WEBHOOK_URL=

# Option B: Resend (email delivery)
# Install: npm install resend
# Then update app/api/contact/route.ts to use the Resend SDK.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@jednamarketing.com
# RESEND_TO_EMAIL=hello@jednamarketing.com
